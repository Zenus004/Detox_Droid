<?xml version="1.0" encoding="utf-8"?>
<!--
    themes.xml — enhanced for Detox Droid
    ✅ Splash screen background synced to app deep background
    ✅ Edge-to-edge enforced (windowTranslucentStatus/Navigation = false)
    ✅ No action bar (Compose handles its own top bars)
    ✅ Ripple disabled system-wide (Compose handles ripple natively)
    ✅ windowAnimationStyle set to null for seamless Compose transitions
-->
<resources>

    <style name="Theme.Detox_Droid" parent="android:Theme.Material.Light.NoActionBar">

        <!-- Core window background — matches BackgroundDark #13141F -->
        <item name="android:windowBackground">#13141F</item>

        <!-- Status & nav bar — fully immersive dark -->
        <item name="android:statusBarColor">#13141F</item>
        <item name="android:navigationBarColor">#13141F</item>

        <!-- Edge-to-edge: let Compose draw behind system bars -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Splash screen background (Android 12+ SplashScreen API) -->
        <item name="android:windowSplashScreenBackground">#13141F</item>

        <!-- Disable default activity transition (Compose Navigation handles it) -->
        <item name="android:windowAnimationStyle">@null</item>

        <!-- Disable legacy ripple overlay (Compose Indication handles it) -->
        <item name="android:colorControlHighlight">#0FFFFFFF</item>

        <!-- Keep status bar icons light (white) on dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

    </style>

    <!--
        SplashTheme — applied only during cold start via AndroidManifest.
        Swap back to Theme.Detox_Droid in Activity.onCreate() before setContent{}.
    -->
    <style name="Theme.Detox_Droid.Splash" parent="Theme.Detox_Droid">
        <item name="android:windowBackground">#13141F</item>
        <item name="android:windowSplashScreenBackground">#13141F</item>
        <!-- Neon green icon tint for the splash screen icon -->
        <item name="android:windowSplashScreenIconBackgroundColor">#1E2030</item>
    </style>

</resources>